<Window x:Class="NESEmulator.PPUDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PPU调试窗口" Height="750" Width="1000"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 控制面板 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button x:Name="RefreshButton" Content="刷新" Width="80" Height="30" Click="Refresh_Click" Margin="0,0,10,0"/>
            <CheckBox x:Name="AutoRefreshCheckBox" Content="自动刷新" VerticalAlignment="Center" IsChecked="True"/>
        </StackPanel>
        
        <!-- 主内容区域 -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Pattern Table和调色板标签页 -->
            <TabItem Header="Pattern Table &amp; 调色板">
                <StackPanel Margin="10">
                        <!-- Pattern Table区域 -->
                        <TextBlock Text="Pattern Table" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Pattern Table 0 -->
                            <StackPanel Grid.Column="0" Margin="10">
                                <TextBlock Text="Pattern Table 0 ($0000-$0FFF)" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border BorderBrush="Gray" BorderThickness="1">
                                    <Image x:Name="PatternTable0Image" Width="256" Height="256" 
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                            </StackPanel>
                            
                            <!-- Pattern Table 1 -->
                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="Pattern Table 1 ($1000-$1FFF)" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border BorderBrush="Gray" BorderThickness="1">
                                    <Image x:Name="PatternTable1Image" Width="256" Height="256" 
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        
                        <!-- 调色板区域 -->
                        <TextBlock Text="调色板" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        
                        <!-- 背景调色板 -->
                        <TextBlock Text="背景调色板" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <StackPanel x:Name="BackgroundPalettesPanel" Orientation="Horizontal" Margin="0,0,0,20"/>
                        
                        <!-- 精灵调色板 -->
                        <TextBlock Text="精灵调色板" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <StackPanel x:Name="SpritePalettesPanel" Orientation="Horizontal" Margin="0,0,0,20"/>
                </StackPanel>
            </TabItem>
            
            <!-- PPU状态标签页 -->
            <TabItem Header="PPU状态">
                <StackPanel Margin="10">
                        <TextBlock Text="PPU寄存器状态" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PPUCTRL ($2000):" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PPUCTRLText" Text="$00" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="PPUCTRLDesc" Text="" VerticalAlignment="Center" Foreground="Gray"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="PPUMASK ($2001):" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PPUMASKText" Text="$00" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="PPUMASKDesc" Text="" VerticalAlignment="Center" Foreground="Gray"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="PPUSTATUS ($2002):" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PPUSTATUSText" Text="$00" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="PPUSTATUSDesc" Text="" VerticalAlignment="Center" Foreground="Gray"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="扫描线:" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ScanlineText" Text="0" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="周期:" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CycleText" Text="0" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="VRAM地址:" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="VRAMAddrText" Text="$0000" VerticalAlignment="Center"/>
                        </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>