<Window x:Class="NESEmulator.NameTableDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NameTable调试窗口" Height="800" Width="1200"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 控制面板 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button x:Name="RefreshButton" Content="刷新" Width="80" Height="30" Click="Refresh_Click" Margin="0,0,10,0"/>
            <CheckBox x:Name="AutoRefreshCheckBox" Content="自动刷新" VerticalAlignment="Center" IsChecked="True" Margin="0,0,20,0"/>
            <CheckBox x:Name="ShowScrollLinesCheckBox" Content="显示滚动线" VerticalAlignment="Center" IsChecked="True" Margin="0,0,20,0"/>
            <CheckBox x:Name="ShowAttributesCheckBox" Content="显示属性" VerticalAlignment="Center" IsChecked="False" Margin="0,0,20,0"/>
            <CheckBox x:Name="IgnorePalettesCheckBox" Content="忽略调色板" VerticalAlignment="Center" IsChecked="False" Margin="0,0,20,0"/>
            <TextBlock Text="显示扫描线:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="ScanlineTextBox" Text="0" Width="50" Height="25" VerticalAlignment="Center" Margin="0,0,10,0"/>
        </StackPanel>
        
        <!-- 主内容区域 -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- NameTable标签页 -->
            <TabItem Header="NameTable">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- NameTable显示区域 -->
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- NameTable 0 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                                <TextBlock Text="NameTable 0 ($2000-$23FF)" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Border BorderBrush="Gray" BorderThickness="2">
                                    <Canvas x:Name="NameTable0Canvas" Width="512" Height="480" Background="Black">
                                        <Image x:Name="NameTable0Image" Width="512" Height="480" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                            
                            <!-- NameTable 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                                <TextBlock Text="NameTable 1 ($2400-$27FF)" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Border BorderBrush="Gray" BorderThickness="2">
                                    <Canvas x:Name="NameTable1Canvas" Width="512" Height="480" Background="Black">
                                        <Image x:Name="NameTable1Image" Width="512" Height="480" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                            
                            <!-- NameTable 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                                <TextBlock Text="NameTable 2 ($2800-$2BFF)" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Border BorderBrush="Gray" BorderThickness="2">
                                    <Canvas x:Name="NameTable2Canvas" Width="512" Height="480" Background="Black">
                                        <Image x:Name="NameTable2Image" Width="512" Height="480" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                            
                            <!-- NameTable 3 -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                                <TextBlock Text="NameTable 3 ($2C00-$2FFF)" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Border BorderBrush="Gray" BorderThickness="2">
                                    <Canvas x:Name="NameTable3Canvas" Width="512" Height="480" Background="Black">
                                        <Image x:Name="NameTable3Image" Width="512" Height="480" 
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                    
                    <!-- 属性面板 -->
                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="当前镜像" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <RadioButton Grid.Row="0" Grid.Column="0" x:Name="HorizontalMirrorRadio" Content="水平" IsChecked="True" Margin="0,0,0,5"/>
                            <RadioButton Grid.Row="1" Grid.Column="0" x:Name="VerticalMirrorRadio" Content="垂直" Margin="0,0,0,5"/>
                            <RadioButton Grid.Row="2" Grid.Column="0" x:Name="SingleScreen0Radio" Content="单屏0" Margin="0,0,0,5"/>
                            <RadioButton Grid.Row="3" Grid.Column="0" x:Name="SingleScreen1Radio" Content="单屏1" Margin="0,0,0,5"/>
                            <RadioButton Grid.Row="4" Grid.Column="0" x:Name="FourScreenRadio" Content="四屏" Margin="0,0,0,5"/>
                        </Grid>
                        
                        <TextBlock Text="Tile ID: 24" FontWeight="Bold" FontSize="14" Margin="0,20,0,10"/>
                        <TextBlock Text="X / Y: 30 / 0" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="PPU Address: 201E" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock Text="Attribute: 0 (23C7)" FontSize="12" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="属性表" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <Grid x:Name="AttributeGrid" Margin="0,0,0,20">
                            <!-- 属性表网格将在代码中动态生成 -->
                        </Grid>
                        
                        <TextBlock Text="滚动信息" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VRAM地址:" Margin="0,0,5,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VRAMAddressText" Text="$0000" Margin="0,0,0,5"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Coarse X:" Margin="0,0,5,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CoarseXText" Text="0" Margin="0,0,0,5"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Coarse Y:" Margin="0,0,5,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CoarseYText" Text="0" Margin="0,0,0,5"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Fine Y:" Margin="0,0,5,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="FineYText" Text="0" Margin="0,0,0,5"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>