<Window x:Class="NESEmulator.KeyBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入设置"
        Height="560"
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="760"
        MinHeight="560">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionText"
                   Grid.Row="0"
                   Margin="0,0,0,12"
                   Text="设置玩家1的键盘和手柄输入。点击“修改”后按下新的按键或手柄按键。"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="键盘">
                <Grid Margin="10,8,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="上"/>
                    <TextBox x:Name="UpKeyTextBox" Grid.Row="0" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="0" Grid.Column="2" Padding="12,4" Tag="Up" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="下"/>
                    <TextBox x:Name="DownKeyTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="1" Grid.Column="2" Padding="12,4" Tag="Down" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="左"/>
                    <TextBox x:Name="LeftKeyTextBox" Grid.Row="2" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="2" Grid.Column="2" Padding="12,4" Tag="Left" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="右"/>
                    <TextBox x:Name="RightKeyTextBox" Grid.Row="3" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="3" Grid.Column="2" Padding="12,4" Tag="Right" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="A 键"/>
                    <TextBox x:Name="AKeyTextBox" Grid.Row="4" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="4" Grid.Column="2" Padding="12,4" Tag="A" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="B 键"/>
                    <TextBox x:Name="BKeyTextBox" Grid.Row="5" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="5" Grid.Column="2" Padding="12,4" Tag="B" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="Select"/>
                    <TextBox x:Name="SelectKeyTextBox" Grid.Row="6" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="6" Grid.Column="2" Padding="12,4" Tag="Select" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="Start"/>
                    <TextBox x:Name="StartKeyTextBox" Grid.Row="7" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="7" Grid.Column="2" Padding="12,4" Tag="Start" Click="ChangeKeyboardBinding_Click">修改</Button>

                    <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="连击 A"/>
                    <TextBox x:Name="TurboAKeyTextBox" Grid.Row="8" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="8" Grid.Column="2" Padding="12,4" Tag="A" Click="ChangeKeyboardTurboBinding_Click">修改</Button>

                    <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="连击 B"/>
                    <TextBox x:Name="TurboBKeyTextBox" Grid.Row="9" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="9" Grid.Column="2" Padding="12,4" Tag="B" Click="ChangeKeyboardTurboBinding_Click">修改</Button>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="手柄">
                <Grid Margin="10,8,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,10">
                        <TextBlock Text="支持 Xbox / XInput 兼容手柄"/>
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="设备"/>
                            <ComboBox x:Name="GamepadDeviceComboBox"
                                      Width="100"
                                      SelectionChanged="GamepadDeviceComboBox_SelectionChanged"/>
                            <TextBlock x:Name="GamepadStatusText"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="未检测"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="上"/>
                    <TextBox x:Name="GamepadUpTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="1" Grid.Column="2" Padding="12,4" Tag="Up" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="下"/>
                    <TextBox x:Name="GamepadDownTextBox" Grid.Row="2" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="2" Grid.Column="2" Padding="12,4" Tag="Down" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="左"/>
                    <TextBox x:Name="GamepadLeftTextBox" Grid.Row="3" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="3" Grid.Column="2" Padding="12,4" Tag="Left" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="右"/>
                    <TextBox x:Name="GamepadRightTextBox" Grid.Row="4" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="4" Grid.Column="2" Padding="12,4" Tag="Right" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="A 键"/>
                    <TextBox x:Name="GamepadATextBox" Grid.Row="5" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="5" Grid.Column="2" Padding="12,4" Tag="A" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="B 键"/>
                    <TextBox x:Name="GamepadBTextBox" Grid.Row="6" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="6" Grid.Column="2" Padding="12,4" Tag="B" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="Select"/>
                    <TextBox x:Name="GamepadSelectTextBox" Grid.Row="7" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="7" Grid.Column="2" Padding="12,4" Tag="Select" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="Start"/>
                    <TextBox x:Name="GamepadStartTextBox" Grid.Row="8" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="8" Grid.Column="2" Padding="12,4" Tag="Start" Click="ChangeGamepadBinding_Click">修改</Button>

                    <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="连击 A"/>
                    <TextBox x:Name="GamepadTurboATextBox" Grid.Row="9" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="9" Grid.Column="2" Padding="12,4" Tag="A" Click="ChangeGamepadTurboBinding_Click">修改</Button>

                    <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,6" VerticalAlignment="Center" Text="连击 B"/>
                    <TextBox x:Name="GamepadTurboBTextBox" Grid.Row="10" Grid.Column="1" Margin="0,4,8,4" IsReadOnly="True"/>
                    <Button Grid.Row="10" Grid.Column="2" Padding="12,4" Tag="B" Click="ChangeGamepadTurboBinding_Click">修改</Button>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,8,0" Padding="14,6" Click="ResetDefault_Click">恢复默认</Button>
            <Button Margin="0,0,8,0" Padding="14,6" Click="Confirm_Click">确定</Button>
            <Button Padding="14,6" Click="Cancel_Click">取消</Button>
        </StackPanel>
    </Grid>
</Window>
