<Window x:Class="NESEmulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NES模拟器"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="加载ROM" Click="LoadROM_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="调试">
                <MenuItem Header="反汇编窗口" Click="OpenDisassemblyWindow_Click"/>
                <MenuItem Header="PPU调试窗口" Click="OpenPPUDebugWindow_Click"/>
                <MenuItem Header="NameTable调试窗口" Click="OpenNameTableDebugWindow_Click"/>
            </MenuItem>
            <MenuItem Header="模拟">
                <MenuItem Header="开始" Click="Start_Click"/>
                <MenuItem Header="暂停" Click="Pause_Click"/>
                <MenuItem Header="重置" Click="Reset_Click"/>
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="玩家1按键设置" Click="OpenPlayer1KeyBindingWindow_Click"/>
                <MenuItem Header="玩家2按键设置" Click="OpenPlayer2KeyBindingWindow_Click"/>
                <Separator/>
                <MenuItem Header="速度 85%" Click="SetSpeed85_Click"/>
                <MenuItem Header="速度 92.5%" Click="SetSpeed925_Click"/>
                <MenuItem Header="速度 100%" Click="SetSpeed100_Click"/>
                <MenuItem Header="速度 107.5%" Click="SetSpeed1075_Click"/>
                <MenuItem Header="速度 115%" Click="SetSpeed115_Click"/>
                <Separator/>
                <MenuItem Header="音量 50%" Click="SetVolume50_Click"/>
                <MenuItem Header="音量 100%" Click="SetVolume100_Click"/>
                <MenuItem Header="音量 150%" Click="SetVolume150_Click"/>
                <MenuItem Header="音量 200%" Click="SetVolume200_Click"/>
                <MenuItem Header="音量 250%" Click="SetVolume250_Click"/>
                <MenuItem Header="音量 300%" Click="SetVolume300_Click"/>
            </MenuItem>
        </Menu>
        
        <!-- 游戏显示区域 -->
        <Border Grid.Row="1" Background="Black" Margin="10">
            <Image x:Name="GameCanvas" Width="512" Height="480" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>
        
        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪 - 请加载ROM文件"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="速度" Margin="0,0,6,0"/>
            </StatusBarItem>
            <StatusBarItem>
                <Slider x:Name="EmulationSpeedSlider"
                        Width="150"
                        Minimum="85"
                        Maximum="115"
                        Value="99.5"
                        SmallChange="0.1"
                        LargeChange="2.5"
                        TickFrequency="1"
                        IsSnapToTickEnabled="False"
                        ValueChanged="EmulationSpeedSlider_ValueChanged"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="SpeedText" Text="99.5%"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="FPSText" Text="FPS: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
